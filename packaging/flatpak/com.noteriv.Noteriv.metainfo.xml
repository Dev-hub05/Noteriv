<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>com.noteriv.Noteriv</id>

  <name>Noteriv</name>
  <summary>Write and sync Markdown notes</summary>

  <metadata_license>CC0-1.0</metadata_license>
  <project_license>MIT</project_license>

  <developer id="com.noteriv">
    <name>Jace</name>
  </developer>

  <description>
    <p>
      Noteriv is a desktop app for writing Markdown notes in local vaults.
      It keeps notes as files, supports links between notes, and includes
      themes, plugins, and optional Git or WebDAV sync.
    </p>
  </description>

  <launchable type="desktop-id">com.noteriv.Noteriv.desktop</launchable>

  <screenshots>
    <screenshot type="default">
      <image>https://raw.githubusercontent.com/thejacedev/Noteriv/main/assets/image.png</image>
      <caption>Editing a Markdown note in Noteriv</caption>
    </screenshot>
  </screenshots>

  <url type="homepage">https://github.com/thejacedev/Noteriv</url>
  <url type="bugtracker">https://github.com/thejacedev/Noteriv/issues</url>

  <content_rating type="oars-1.1" />

  <releases>
    <release version="2.1.1" date="2026-05-30">
      <description>
        <p>Fixes Git sync getting stuck after rebase conflicts. Noteriv now reports the conflict so it can be resolved.</p>
      </description>
    </release>
  </releases>
</component>
