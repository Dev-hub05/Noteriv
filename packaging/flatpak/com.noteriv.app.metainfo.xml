<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>com.noteriv.app</id>

  <name>Noteriv</name>
  <summary>Modern markdown editor with plugins, themes, and sync</summary>

  <metadata_license>CC0-1.0</metadata_license>
  <project_license>MIT</project_license>

  <developer id="com.noteriv">
    <name>Jace</name>
  </developer>

  <description>
    <p>
      Noteriv is a modern markdown editor with a plugin API, themes, and
      Git/WebDAV sync. Organize notes into vaults, link them together, and
      extend the editor with plugins.
    </p>
  </description>

  <launchable type="desktop-id">com.noteriv.app.desktop</launchable>

  <!-- STOPGAP: points at the README banner (exists on main, so the build won't
       404). Flathub reviewers prefer a real screenshot of the app UI — replace
       this with a genuine 16:9 PNG before/at submission. -->
  <screenshots>
    <screenshot type="default">
      <image>https://raw.githubusercontent.com/thejacedev/Noteriv/main/desktop/public/banner.png</image>
      <caption>Noteriv</caption>
    </screenshot>
  </screenshots>

  <url type="homepage">https://github.com/thejacedev/Noteriv</url>
  <url type="bugtracker">https://github.com/thejacedev/Noteriv/issues</url>

  <!-- Tells stores there's no objectionable content; required by Flathub. -->
  <content_rating type="oars-1.1" />

  <releases>
    <release version="2.0.3" date="2026-05-30">
      <description>
        <p>Flatpak support; self-updater disabled inside Flatpak (updates managed by Flathub).</p>
      </description>
    </release>
  </releases>
</component>
